# SQ1 OSINT environment variables
# Copy this file to .env and fill in only the keys you use.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# Core local storage
# -----------------------------------------------------------------------------
# Defaults to %USERPROFILE%\.sq1-osint\db.json when unset.
# SQ1_DB_PATH=C:\Users\YOUR_USER\.sq1-osint\db.json

# Defaults to %USERPROFILE%\.sq1-osint\leads.json when unset.
# SQ1_LEADS_DB_PATH=C:\Users\YOUR_USER\.sq1-osint\leads.json

# Customer intelligence can call the marketing module through this URL.
SQ1_MARKETING_API_URL=http://127.0.0.1:3002

# -----------------------------------------------------------------------------
# AI backend
# Only one provider key is required. Provider priority:
# Anthropic -> OpenAI -> OpenRouter -> Gemini.
# -----------------------------------------------------------------------------

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI or OpenAI-compatible endpoint
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Local OpenAI-compatible server example:
# OPENAI_BASE_URL=http://127.0.0.1:8080/v1
# OPENAI_API_KEY=sk-no-key-required

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# Google Gemini
# GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Ollama is used by the legacy web UI when no hosted provider is configured.
OLLAMA_HOST=http://127.0.0.1:11434

# -----------------------------------------------------------------------------
# Optional OSINT data providers
# -----------------------------------------------------------------------------

# HaveIBeenPwned v3
# HIBP_API_KEY=your_hibp_key

# DeHashed
# DEHASHED_EMAIL=your_account_email@example.com
# DEHASHED_API_KEY=your_dehashed_api_key

# IP intelligence
# IPINFO_TOKEN=your_ipinfo_token
# IP2LOCATION_API_KEY=your_ip2location_key

# Threat intelligence sources
# VIRUSTOTAL_API_KEY=your_virustotal_key
# SHODAN_API_KEY=your_shodan_key
# CENSYS_API_ID=your_censys_id
# CENSYS_SECRET=your_censys_secret
# ABUSEIPDB_API_KEY=your_abuseipdb_key

# GitHub profile/repo/email discovery
# GITHUB_TOKEN=your_github_token

# Bright Data for live dork search and web unlocking
# BRIGHTDATA_API_KEY=your_brightdata_key
BRIGHTDATA_SERP_ZONE=serp_api1
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker1

# -----------------------------------------------------------------------------
# Optional demo recording tools
# -----------------------------------------------------------------------------
FFMPEG_BIN=ffmpeg
GIFSICLE_BIN=gifsicle
