# SQ1 Marketing Module environment variables
# Copy this file to marketing/.env and fill in only the keys you use.
# Never commit real secrets.

# -----------------------------------------------------------------------------
# AI backend
# Marketing auto-detects providers in this order:
# Anthropic -> OpenRouter -> OpenAI -> Gemini.
# Leave all keys blank to use deterministic fallback copy/assets.
# -----------------------------------------------------------------------------

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenAI or OpenAI-compatible endpoint
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Google Gemini
# GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Disable outbound LLM calls while developing/tests and use fallback generators.
MARKETING_DISABLE_LLM=false

# Keep visual generation fast by default. Set either to true only when you want
# AI-written visual/video copy and can wait for the external model call.
MARKETING_USE_AI_VISUALS=false
MARKETING_USE_AI_VIDEO=false

# -----------------------------------------------------------------------------
# OSINT integration
# -----------------------------------------------------------------------------
# FastAPI OSINT API runs here:
#   uvicorn openosint.api.main:app --host 127.0.0.1 --port 8000 --reload
OSINT_API_URL=http://127.0.0.1:8000

# Set true to pull /api/intel/unmarketed from OSINT instead of mock data.
MARKETING_USE_LIVE_OSINT=true

# -----------------------------------------------------------------------------
# Marketing API server
# -----------------------------------------------------------------------------
PORT=3002
MARKETING_DB_PATH=./.runtime/db.json

# Optional bearer token for non-read-only Marketing API requests.
# Leave blank for local development.
MARKETING_API_TOKEN=

# -----------------------------------------------------------------------------
# Communications
# -----------------------------------------------------------------------------
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://...
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# EMAIL_FROM=you@example.com
# EMAIL_USER=you@example.com
# EMAIL_PASS=app_password

# -----------------------------------------------------------------------------
# Smoke-test overrides
# -----------------------------------------------------------------------------
MARKETING_SMOKE_API_URL=http://127.0.0.1:3002
MARKETING_SMOKE_UI_PORT=5174
