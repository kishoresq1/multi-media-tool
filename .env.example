# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_DB=unified_multimedia
POSTGRES_USER=ump_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://ump_user:change-me@postgres:5432/unified_multimedia

# ─────────────────────────────────────────────
# Redis (Celery broker + cache)
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# Service ports (override if host port conflicts)
# ─────────────────────────────────────────────
INTELLIGENCE_SERVICE_PORT=8000
CONTENT_SERVICE_PORT=3000
NGINX_PORT=80

# ─────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────
# Generate a strong random value: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret

# ─────────────────────────────────────────────
# LLM providers — at least one key enables AI content generation
# Priority order: Anthropic → OpenRouter → OpenAI → Gemini
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# Ollama — local LLM for intelligence enrichment
# ─────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_ENABLED=true

# ─────────────────────────────────────────────
# LinkedIn OAuth 2.0
# Register an app at https://developer.linkedin.com
# ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost/auth/linkedin/callback

# ─────────────────────────────────────────────
# Notification webhooks
# ─────────────────────────────────────────────
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=

# ─────────────────────────────────────────────
# Intelligence collection settings
# ─────────────────────────────────────────────
# Collection interval in minutes (5–1440, default 20)
COLLECTION_INTERVAL_MINUTES=20
# Minimum confidence score for feed inclusion (0.0–1.0)
MIN_CONFIDENCE_SCORE=0.5
# Number of days to look back on initial collection
DEFAULT_LOOKBACK_DAYS=30
DEBUG=false

# ─────────────────────────────────────────────
# Optional collector API keys
# (collectors degrade gracefully when keys are absent)
# ─────────────────────────────────────────────
# NVD API — increases rate limits; register at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# GitHub token — used for PoC/exploit repository searches
GITHUB_TOKEN=

# Reddit API — optional; public JSON fallback is used when absent
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=unified-multimedia-platform/1.0

# X/Twitter via Nitter — no API key needed; comma-separated instance list
NITTER_INSTANCES=https://nitter.poast.org,https://xcancel.com,https://nitter.privacydev.net
NITTER_VERIFY_SSL=false
NITTER_TIMEOUT_SECONDS=15
