# X/Twitter via Nitter (no API key needed)
# Comma-separated Nitter instances — rotates if one is down/blocked
# Use your own self-hosted Nitter if public instances return 403/bot challenges
ZDR_NITTER_INSTANCES=https://nitter.poast.org,https://xcancel.com,https://nitter.privacydev.net
ZDR_NITTER_VERIFY_SSL=false
ZDR_NITTER_TIMEOUT_SECONDS=15

# Optional API keys

# Reddit API (optional — public JSON API used as fallback)
ZDR_REDDIT_CLIENT_ID=
ZDR_REDDIT_CLIENT_SECRET=
ZDR_REDDIT_USER_AGENT=zero-day-radar/0.1
ZDR_GITHUB_TOKEN=
ZDR_NVD_API_KEY=

# Hunt defaults (ZDR_ prefix avoids conflicts with system env vars)
ZDR_DEFAULT_LOOKBACK_DAYS=30
ZDR_MIN_CONFIDENCE_SCORE=0.5
ZDR_DEBUG=false
ZDR_DATABASE_URL=sqlite+aiosqlite:///./data/zero_day_radar.db

# Celery + Redis (background jobs every 20 min)
ZDR_REDIS_URL=redis://localhost:6379/0
ZDR_CELERY_BEAT_INTERVAL_MINUTES=20
ZDR_CELERY_ENABLED=true

# Ollama LLM (unified intel enrichment)
ZDR_OLLAMA_ENABLED=true
ZDR_OLLAMA_BASE_URL=http://localhost:11434
ZDR_OLLAMA_MODEL=llama3.2
ZDR_OLLAMA_TIMEOUT_SECONDS=120

# API keys also use ZDR_ prefix:
# ZDR_REDDIT_CLIENT_ID=
# ZDR_GITHUB_TOKEN=
